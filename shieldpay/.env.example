# ShieldPay — copy to .env and adjust. Never commit real secrets.
# Default matches the assignment; if the port is busy, set PORT to a free port (e.g. 8792).
PORT=8788
NODE_ENV=development

# SQLite database file (created on first run)
DATABASE_PATH=./backend/data/shieldpay.db

# 32-byte key, base64-encoded, for AES-256-GCM encryption of PAN/CVV at rest (required).
# Generate with: openssl rand -base64 32
CARD_ENCRYPTION_KEY=

# ARKO-LAB-07: JWT_SECRET must be a long, random string in production (e.g. openssl rand -base64 48).
# If unset, the server uses a weak built-in default so the lab can demonstrate secret handling mistakes.
JWT_SECRET=

# Seeded admin user (required for first-time DB initialization; no defaults in code)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Session secret for express-session (use a strong random value in production)
SESSION_SECRET=dev-session-change-me
