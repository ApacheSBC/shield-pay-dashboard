# ShieldPay — copy to .env and adjust. Never commit real secrets.
# Default matches the assignment; if the port is busy, set PORT to a free port (e.g. 8792).
PORT=8788
NODE_ENV=development

# SQLite database file (created on first run)
DATABASE_PATH=./backend/data/shieldpay.db

# 32-byte key, base64-encoded, for AES-256-GCM encryption of PAN/CVV at rest (required).
# Generate with: openssl rand -base64 32
CARD_ENCRYPTION_KEY=

# JWT signing secret (required). Generate with: openssl rand -base64 48
JWT_SECRET=

# Seeded admin user (required for first-time DB initialization; no defaults in code)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Required for admin impersonation step-up MFA (shared secret for 6-digit rolling code)
ADMIN_MFA_SECRET=

# Session secret for express-session (required). Generate with: openssl rand -base64 32
SESSION_SECRET=

# Optional Redis URL for distributed auth rate limiting. If empty, in-memory limiter is used.
# Example: redis://127.0.0.1:6379
RATE_LIMIT_REDIS_URL=

# Comma-separated trusted origins for CORS (exact origins only, no wildcard when credentials are used).
# Defaults to http://127.0.0.1:PORT and http://localhost:PORT when empty.
# Example: CORS_ALLOWED_ORIGINS=http://127.0.0.1:8788,http://localhost:8788
CORS_ALLOWED_ORIGINS=
